# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=

# LlamaParse — cloud.llamaindex.ai (PDF text extraction)
LLAMAPARSE_API_KEY=

# Supabase — project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay — dashboard.razorpay.com
# Test keys start with rzp_test_; live keys with rzp_live_
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret from Razorpay Dashboard → Settings → Webhooks (HMAC for /api/payment/webhook)
RAZORPAY_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 — analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=

# Google Sheets webhook for /contact form submissions.
# Set this to the "Web app" URL of an Apps Script bound to your sheet.
# Leave blank to log messages to stdout only (Vercel logs).
GOOGLE_SHEETS_WEBHOOK_URL=
# Optional shared secret echoed back to the Apps Script for validation.
GOOGLE_SHEETS_SHARED_SECRET=
